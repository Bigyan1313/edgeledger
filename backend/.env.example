# Copy to .env for local dev. In production, set these in the Render dashboard.

# Postgres connection string. Local: your local DB. Prod: the Neon connection string.
DATABASE_URL="postgresql://USER@localhost:5432/edgeledger"

# Long random string used to sign JWTs. Generate with:
#   node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
# IMPORTANT: use a DIFFERENT, fresh value in production.
JWT_SECRET="replace-with-a-long-random-string"

# Google OAuth Client ID (public value). Same one used by the frontend.
GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# Production only: comma-separated list of allowed frontend origins (your Vercel URL).
# Leave unset locally — it defaults to the Vite dev ports.
# FRONTEND_ORIGIN="https://your-app.vercel.app"
