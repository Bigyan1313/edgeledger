# Copy to .env for local dev. In production, set these in the Vercel dashboard.
# Only VITE_-prefixed vars are exposed to the browser. Restart the dev server after edits.

# Google OAuth Client ID (public value). Same one used by the backend.
VITE_GOOGLE_CLIENT_ID="your-client-id.apps.googleusercontent.com"

# Production only: the deployed backend API base URL (Render URL + /api).
# Leave unset locally — it defaults to http://localhost:3001/api.
# VITE_API_URL="https://your-backend.onrender.com/api"
